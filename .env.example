# Supabaseの接続情報（Supabaseダッシュボード → Project Settings → Data API / API Keys）
# このファイルをコピーして「.env.local」を作り、実際の値を入れてください。
# .env.local はGitに上げない設定になっています（公開禁止）。

# Project URL（例: https://xxxxxxxx.supabase.co）
SUPABASE_URL=

# service_role キー（secret。絶対に公開しないこと）
SUPABASE_SERVICE_ROLE_KEY=

# アプリに入るための合言葉（好きな文字列）
APP_PASSPHRASE=

# セッション用の秘密の文字列（ランダムな長い文字列を入れる）
APP_SESSION_SECRET=
